apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: stardrive-public
  namespace: gateway-system
spec:
  gatewayClassName: cilium
  listeners:
    - name: http
      protocol: HTTP
      port: 80
      hostname: "{{ .AppWildcardDomain }}"
      allowedRoutes:
        namespaces:
          from: All
    - name: https
      protocol: HTTPS
      port: 443
      hostname: "{{ .AppWildcardDomain }}"
      tls:
        mode: Terminate
        certificateRefs:
          - kind: Secret
            name: stardrive-wildcard-tls
      allowedRoutes:
        namespaces:
          from: All
