apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: stardrive-http-redirect
  namespace: gateway-system
spec:
  parentRefs:
    - name: stardrive-public
      sectionName: http
  hostnames:
    - "{{ .AppWildcardDomain }}"
  rules:
    - filters:
        - type: RequestRedirect
          requestRedirect:
            scheme: https
            statusCode: 301
